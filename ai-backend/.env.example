# Copy to .env (gitignored). All values are SERVER-SIDE secrets — do not
# expose them in the mobile app bundle.

# OpenAI
OPENAI_API_KEY=sk-proj-...your-key-here...
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_STT_MODEL=whisper-1


# Supabase — used to verify the user's JWT against the project's auth.
SUPABASE_URL=https://sgvalritfnyiwxjwpqjj.supabase.co
SUPABASE_ANON_KEY=sb_publishable_4xQz3k0RiARgKLmWLgLnFQ_Rl_BUBGr

# Server
PORT=8787
# Comma-separated list of allowed origins for browser/dev callers.
# Mobile app calls don't send Origin so they're always allowed.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Optional: bypass auth in dev (NEVER set in production).
ALLOW_ANON=false
