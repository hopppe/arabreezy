# Copy to .env and fill in. Vars prefixed EXPO_PUBLIC_ are inlined into the JS bundle
# by Metro at build time — safe for publishable keys, NEVER for service/secret keys.

EXPO_PUBLIC_SUPABASE_URL=https://xeppwiugjvnigttpseev.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Set true once migrations + seed are applied to start reading content from Supabase.
# Default (unset/false) keeps the app on the local dialect bundles.
EXPO_PUBLIC_USE_SUPABASE_CONTENT=false

# URL of the AI proxy backend (./ai-backend) that holds the OpenAI secret key.
# In dev: leave unset — the app auto-derives http://<metro-lan-ip>:8787 from
# Constants.expoConfig.hostUri, so a phone on the same Wi-Fi just works.
# In prod: set the public hostname, e.g. https://api.arabreezy.example.com
EXPO_PUBLIC_AI_BACKEND_URL=
# Optional: override the backend port (defaults to 8787).
EXPO_PUBLIC_AI_BACKEND_PORT=

# Google Sign-In (https://console.cloud.google.com/apis/credentials)
# Create OAuth 2.0 client IDs for iOS, Android, and Web. Add the same Web client
# as an Authorized Provider in Supabase (Auth → Providers → Google). The Web
# client id is what Supabase uses to verify Google's ID token.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Reversed iOS client id, used as the iOS URL scheme. From the iOS client's
# `iosUrlScheme` field — e.g. com.googleusercontent.apps.1234567890-abcdefghi
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# RevenueCat (https://app.revenuecat.com). One PUBLIC key per platform — safe
# to inline into the bundle. The webhook secret (server-side) stays in
# ai-backend's env, never here. Without these set, the paywall UI still renders
# in dev with fallback prices but actual purchases fail with a friendly error.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
# Entitlement identifier in your RevenueCat dashboard. Defaults to "pro".
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT=pro
